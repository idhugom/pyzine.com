---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Card from '../components/Card.astro';
import { formatDate, isoDate, readingLabel, withHeadingIds, extractHeadings } from '../lib/format';
import '../styles/article.css';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((article) => ({
    params: { slug: article.data.slug },
    props: { article, all: articles },
  }));
}

const { article, all } = Astro.props;
const d = article.data;

const bodyHtml = withHeadingIds(d.bodyHtml);
const headings = extractHeadings(bodyHtml);

// related: newest others sharing a topic, else newest others
const others = all.filter((a) => a.id !== article.id);
const sameTopic = others.filter((a) => a.data.topics?.some((t) => d.topics?.includes(t)));
const related = (sameTopic.length >= 3 ? sameTopic : others)
  .sort((a, b) => +b.data.date - +a.data.date)
  .slice(0, 3);

const url = `https://www.pyzine.com/${d.slug}`;
const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: d.title,
  description: d.metaDescription,
  image: d.image ? new URL(d.image.src, Astro.site).href : new URL('/og-default.png', Astro.site).href,
  datePublished: isoDate(d.date),
  dateModified: isoDate(d.modified ?? d.date),
  author: { '@type': 'Organization', name: 'Pyzine' },
  publisher: {
    '@type': 'Organization',
    name: 'Pyzine',
    logo: { '@type': 'ImageObject', url: new URL('/l.png', Astro.site).href },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
  inLanguage: 'fr-FR',
};
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://www.pyzine.com/' },
    { '@type': 'ListItem', position: 2, name: 'Le mag', item: 'https://www.pyzine.com/articles' },
    { '@type': 'ListItem', position: 3, name: d.title, item: url },
  ],
};
const faqLd = d.faq.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: d.faq.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    }
  : null;
const jsonLd = [articleLd, breadcrumbLd, ...(faqLd ? [faqLd] : [])];
const shareUrl = encodeURIComponent(url);
const shareTitle = encodeURIComponent(d.title);
---
<Base
  title={d.metaTitle ?? d.title}
  description={d.metaDescription}
  image={d.image?.src ?? null}
  type="article"
  current="/articles"
  jsonLd={jsonLd}
>
  <div class="progress" id="progress"></div>

  <article class="wrap" style="padding-top:1.5rem">
    <nav aria-label="Fil d'ariane" style="font-size:.82rem;color:var(--ink-3);margin-bottom:1.5rem">
      <a href="/" class="swipe">Accueil</a> <span style="color:var(--accent)">/</span>
      <a href="/articles" class="swipe">Le mag</a>
    </nav>

    <header class="article-hero">
      <span class="kicker reveal">{d.topics?.[0] ?? 'Le mag'}</span>
      <h1 class="article-hero__title reveal" data-delay="1">{d.title}</h1>
      <p class="article-hero__lede reveal" data-delay="2">{d.excerpt}</p>
      <div class="article-hero__meta reveal" data-delay="3">
        <span>Par la rédaction</span><span class="sep"></span>
        <time datetime={d.date.toISOString()}>{formatDate(d.date)}</time><span class="sep"></span>
        <span>{readingLabel(d.readingTime)}</span>
      </div>
    </header>

    {d.image && (
      <figure class="article-cover reveal" data-delay="2">
        <img src={d.image.src} alt={d.image.alt || d.title} width={d.image.width ?? 1600} height={d.image.height ?? 900} fetchpriority="high" decoding="async" />
      </figure>
    )}

    <div class="article-body-grid">
      <div>
        {d.keyTakeaways.length > 0 && (
          <aside class="takeaways reveal">
            <span class="takeaways__label">À retenir</span>
            <ul>{d.keyTakeaways.map((t) => <li><span>{t}</span></li>)}</ul>
          </aside>
        )}

        <div class="prose" id="prose" set:html={bodyHtml} />

        {d.faq.length > 0 && (
          <section style="margin-top:3rem">
            <h2 class="display" style="font-size:clamp(1.7rem,3.4vw,2.4rem)">Questions fréquentes</h2>
            <div class="faq">
              {d.faq.map((f) => (
                <details class="faq__item">
                  <summary>{f.q}</summary>
                  <div class="faq__a" set:html={f.a} />
                </details>
              ))}
            </div>
          </section>
        )}
      </div>

      <aside class="rail" aria-label="Compléments">
        {headings.length > 2 && (
          <div class="rail__box rail__box--toc">
            <h5>Sommaire</h5>
            <ul class="toc" id="toc">
              {headings.map((h) => <li><a href={`#${h.id}`}>{h.text}</a></li>)}
            </ul>
          </div>
        )}
        <div class="rail__box">
          <h5>Partager</h5>
          <div class="share">
            <a href={`https://twitter.com/intent/tweet?url=${shareUrl}&text=${shareTitle}`} target="_blank" rel="noopener" aria-label="Partager sur X">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M18.9 1.5h3.7l-8 9.2 9.5 12.6h-7.4l-5.8-7.6-6.7 7.6H.5l8.6-9.8L0 1.5h7.6l5.3 7 6-7Zm-1.3 19.9h2L6.5 3.6H4.4L17.6 21.4Z"/></svg>
            </a>
            <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${shareUrl}`} target="_blank" rel="noopener" aria-label="Partager sur LinkedIn">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M20.4 3H3.6C2.7 3 2 3.7 2 4.6v14.8c0 .9.7 1.6 1.6 1.6h16.8c.9 0 1.6-.7 1.6-1.6V4.6c0-.9-.7-1.6-1.6-1.6zM8 18H5.3V9.7H8V18zM6.6 8.5a1.6 1.6 0 110-3.2 1.6 1.6 0 010 3.2zM18.7 18H16v-4.1c0-1 0-2.2-1.4-2.2s-1.6 1.1-1.6 2.2V18h-2.7V9.7h2.6v1.1h.1c.4-.7 1.3-1.4 2.6-1.4 2.8 0 3.3 1.8 3.3 4.2V18z"/></svg>
            </a>
            <a href={`https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`} target="_blank" rel="noopener" aria-label="Partager sur Facebook">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 10-11.6 9.9v-7H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.5h-1.2c-1.2 0-1.6.8-1.6 1.6V12h2.7l-.4 2.9h-2.3v7A10 10 0 0022 12z"/></svg>
            </a>
          </div>
        </div>
        <div class="rail__box" style="background:var(--ink);color:#fff;border-color:var(--ink)">
          <h5 style="color:var(--accent)">Newsletter</h5>
          <p style="font-size:.9rem;color:rgba(255,255,255,.75);margin-bottom:.8rem">Le meilleur de Pyzine, une fois par semaine.</p>
          <a href="#newsletter" class="btn btn--accent" style="width:100%;justify-content:center">S'abonner</a>
        </div>
      </aside>
    </div>

    <div class="wrap" style="padding:0;margin-top:3rem">
      <div class="article-tags">
        {(d.topics ?? []).map((t) => <a href={`/articles?t=${encodeURIComponent(t)}`}>#{t}</a>)}
      </div>
    </div>
  </article>

  {related.length > 0 && (
    <section class="section wrap">
      <div class="sec-head reveal"><h2 class="display">À lire ensuite</h2></div>
      <div class="mosaic">
        {related.map((a, i) => <Card article={a} variant="default" delay={(i % 3) + 1} />)}
      </div>
    </section>
  )}

  <script is:inline>
    // Reading progress
    (function () {
      var bar = document.getElementById('progress');
      var prose = document.getElementById('prose');
      if (!bar || !prose) return;
      function upd() {
        var rect = prose.getBoundingClientRect();
        var total = prose.offsetHeight - window.innerHeight;
        var done = Math.min(Math.max(-rect.top, 0), Math.max(total, 1));
        bar.style.width = (total > 0 ? (done / total) * 100 : 0) + '%';
      }
      upd();
      window.addEventListener('scroll', upd, { passive: true });
      window.addEventListener('resize', upd);
    })();
    // TOC active state
    (function () {
      var links = Array.from(document.querySelectorAll('#toc a'));
      if (!links.length) return;
      var map = {};
      links.forEach(function (a) { map[a.getAttribute('href').slice(1)] = a; });
      var io = new IntersectionObserver(function (ents) {
        ents.forEach(function (e) {
          if (e.isIntersecting) {
            links.forEach(function (l) { l.classList.remove('active'); });
            var a = map[e.target.id];
            if (a) a.classList.add('active');
          }
        });
      }, { rootMargin: '-20% 0px -70% 0px' });
      document.querySelectorAll('#prose h2[id]').forEach(function (h) { io.observe(h); });
    })();
  </script>
</Base>
