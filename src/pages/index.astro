---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Card from '../components/Card.astro';
import { formatDate, readingLabel } from '../lib/format';

const all = (await getCollection('articles')).sort((a, b) => +b.data.date - +a.data.date);
const featured = all.find((a) => a.data.featured) ?? all[0];
const rest = all.filter((a) => a.id !== featured?.id);

const mosaic = rest.slice(0, 7);
const fil = rest.slice(7, 15);
const count = all.length;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Pyzine',
  alternateName: 'Pyzine — Le mag',
  url: 'https://www.pyzine.com',
  description: 'Le mag qui décrypte, explore et raconte.',
  inLanguage: 'fr-FR',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://www.pyzine.com/articles?q={query}',
    'query-input': 'required name=query',
  },
};
const fd = featured?.data;
---
<Base
  title="Pyzine — Le mag qui décrypte, explore et raconte"
  description="Pyzine, le magazine indépendant : des articles fouillés, vérifiés et utiles sur la tech, la culture, les voyages et l'art de vivre."
  current="/"
  jsonLd={jsonLd}
>
  {fd && (
    <section class="hero">
      <div class="wrap">
        <div class="hero__grid">
          <div class="hero__text">
            <span class="hero__index" aria-hidden="true">01</span>
            <span class="kicker reveal">{fd.topics?.[0] ?? 'À la une'}</span>
            <h1 class="display hero__title reveal" data-delay="1">
              <a href={`/${fd.slug}`} set:html={fd.title.replace(/ ([^ ]+)$/, ' <em>$1</em>')}></a>
            </h1>
            <p class="lede reveal" data-delay="2" style="margin-top:1.3rem;max-width:52ch">{fd.excerpt}</p>
            <div class="hero__meta reveal" data-delay="3">
              <time datetime={fd.date.toISOString()}>{formatDate(fd.date)}</time>
              <span>·</span>
              <span>{readingLabel(fd.readingTime)}</span>
              <a class="arrow-link" href={`/${fd.slug}`} style="margin-left:.4rem">
                Lire l'article
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
              </a>
            </div>
          </div>
          <div class="hero__media reveal" data-delay="2">
            <a href={`/${fd.slug}`} aria-label={fd.title}>
              {fd.image ? (
                <img src={fd.image.src} alt={fd.image.alt || fd.title} width={fd.image.width ?? 1024} height={fd.image.height ?? 683} fetchpriority="high" decoding="async" />
              ) : (
                <div style="width:100%;height:100%;display:grid;place-items:center;background:var(--accent-050);color:var(--accent-600);font-family:var(--font-display);font-size:3rem">Pyzine</div>
              )}
            </a>
            <div class="badge-spin" aria-hidden="true">
              <svg viewBox="0 0 120 120">
                <defs><path id="cir" d="M60,60 m-46,0 a46,46 0 1,1 92,0 a46,46 0 1,1 -92,0"/></defs>
                <g class="ring"><text font-size="11.4" font-weight="700" letter-spacing="3" fill="#0a0a0b"><textPath href="#cir" startOffset="0">PYZINE · LE MAG · À LA UNE · PYZINE · LE MAG · </textPath></text></g>
              </svg>
              <span class="dot">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M7 7h10v10"/></svg>
              </span>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  {mosaic.length > 0 && (
    <section class="section wrap">
      <div class="sec-head reveal">
        <h2 class="display">À la une</h2>
        <a class="arrow-link" href="/articles">Tout explorer
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </div>
      <div class="mosaic">
        {mosaic.map((a, i) => (
          <Card article={a} variant={i === 0 ? 'wide' : i === 1 ? 'wide' : 'default'} delay={(i % 3) + 1} />
        ))}
      </div>
    </section>
  )}

  <section class="section" style="background:var(--ink);color:#fff">
    <div class="wrap" style="text-align:center;max-width:900px">
      <p class="display reveal" style="font-size:clamp(1.9rem,4.5vw,3.4rem);line-height:1.1">
        On ne publie pas <em style="color:var(--accent);font-style:italic">plus</em>.
        On publie <em style="color:var(--accent);font-style:italic">mieux</em> —
        des articles fouillés, vérifiés et faits pour durer.
      </p>
      <div class="reveal" data-delay="1" style="margin-top:2rem;display:flex;gap:2.5rem;justify-content:center;flex-wrap:wrap">
        <div><div class="display" style="font-size:2.6rem;color:var(--accent)">{count}</div><div style="color:rgba(255,255,255,.6);font-size:.85rem">articles</div></div>
        <div><div class="display" style="font-size:2.6rem;color:var(--accent)">100%</div><div style="color:rgba(255,255,255,.6);font-size:.85rem">écrit avec soin</div></div>
        <div><div class="display" style="font-size:2.6rem;color:var(--accent)">0</div><div style="color:rgba(255,255,255,.6);font-size:.85rem">clickbait</div></div>
      </div>
    </div>
  </section>

  {fil.length > 0 && (
    <section class="section wrap">
      <div class="sec-head reveal"><h2 class="display">Le fil</h2></div>
      <div class="rowlist">
        {fil.map((a, i) => (
          <a class="rowitem reveal" href={`/${a.data.slug}`} data-delay={(i % 3) + 1}>
            <span class="rowitem__num">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <div class="rowitem__title">{a.data.title}</div>
              <div class="card__meta" style="margin-top:.4rem">
                <span>{a.data.topics?.[0] ?? 'Le mag'}</span><span class="dot"></span>
                <time datetime={a.data.date.toISOString()}>{formatDate(a.data.date)}</time>
              </div>
            </div>
            {a.data.image && (
              <span class="rowitem__thumb"><img src={a.data.image.src} alt="" width="92" height="62" loading="lazy" /></span>
            )}
          </a>
        ))}
      </div>
    </section>
  )}
</Base>
