---
import { formatDate, readingLabel } from '../lib/format';
import type { CollectionEntry } from 'astro:content';

interface Props {
  article: CollectionEntry<'articles'>;
  variant?: 'default' | 'wide' | 'feature' | 'full';
  index?: number;
  delay?: number;
}
const { article, variant = 'default', index, delay = 0 } = Astro.props;
const d = article.data;
const cls = { default: 'card', wide: 'card card--wide', feature: 'card card--feature', full: 'card card--full' }[variant];
const topic = d.topics?.[0] ?? 'Le mag';
---
<article class={`${cls} reveal`} data-delay={delay}>
  <a class="card__link" href={`/${d.slug}`} aria-label={d.title}></a>
  <div class="card__media">
    {d.image ? (
      <img src={d.image.src} alt={d.image.alt || d.title}
        width={d.image.width ?? 800} height={d.image.height ?? 533}
        loading={variant === 'feature' ? 'eager' : 'lazy'} decoding="async" />
    ) : (
      <div style="width:100%;height:100%;display:grid;place-items:center;background:var(--accent-050);color:var(--accent-600);font-family:var(--font-display);font-size:2rem">Pyzine</div>
    )}
    <span class="card__tag">{topic}</span>
  </div>
  <h3 class="card__title">{d.title}</h3>
  {(variant === 'feature' || variant === 'wide') && <p class="card__excerpt">{d.excerpt}</p>}
  <div class="card__meta">
    {typeof index === 'number' && <span>{String(index).padStart(2, '0')}</span>}
    <time datetime={d.date.toISOString()}>{formatDate(d.date)}</time>
    <span class="dot"></span>
    <span>{readingLabel(d.readingTime)}</span>
  </div>
</article>
